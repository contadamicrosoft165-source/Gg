local running = false

local function countIngredients()
    local backpack   = LocalPlayer:WaitForChild("Backpack")
    local character  = LocalPlayer.Character
    local counts     = { water = 0, gelatin = 0, ["sugar block bag"] = 0 }
    local msCounts   = { small = 0, medium = 0, large = 0 }

    local function scanContainer(container)
        for _, item in ipairs(container:GetChildren()) do
            local name = item.Name:lower()
            for _, ingredient in ipairs(INGREDIENTS) do
                if name:find(ingredient) then
                    counts[ingredient] = (counts[ingredient] or 0) + 1
                end
            end
            for _, size in ipairs(MS_SIZES) do
                if name:find(size) then
                    msCounts[size] = (msCounts[size] or 0) + 1
                end
            end
        end
    end

    scanContainer(backpack)
    if character then scanContainer(character) end
    return counts, msCounts
end

local function updateUI(counts, msCounts)
    local total = msCounts.small + msCounts.medium + msCounts.large
    lblRemaining.Text  = "Sisa MS: " .. total
    lblProduced.Text   = ("MS Sudah Jadi:\nSmall: %d\nMedium: %d\nLarge: %d")
                            :format(msCounts.small, msCounts.medium, msCounts.large)
    lblIngredients.Text = ("Water: %d\nSugar Block Bag: %d\nGelatin: %d")
                            :format(counts["water"], counts["sugar block bag"], counts["gelatin"])
end

local function equipAndUse(itemName)
    local item = LocalPlayer.Backpack:FindFirstChild(itemName)
    if not item then return false end
    item.Parent = LocalPlayer.Character
    task.wait(0.05)
    VirtualInput:SendKeyEvent(true,  Enum.KeyCode.E, false, game)
    task.wait(0.1)
    VirtualInput:SendKeyEvent(false, Enum.KeyCode.E, false, game)
    return true
end

