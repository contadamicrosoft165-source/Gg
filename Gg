local function makeLabel(parent, size, pos, textColor, font, textSize, text, xAlign, yAlign)
    local label = Instance.new("TextLabel", parent)
    label.Size                = size
    label.Position            = pos
    label.BackgroundTransparency = 1
    label.TextColor3          = textColor
    label.Font                = font
    label.TextSize            = textSize
    label.Text                = text
    if xAlign then label.TextXAlignment = xAlign end
    if yAlign then label.TextYAlignment = yAlign end
    return label
end

